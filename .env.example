# DS Copilot - local developer reference only
# The shipping plugin does NOT read .env at runtime.
# Production/runtime settings still come from Zotero prefs and the plugin Settings pane.

# Required for `npm start`
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/Applications/Zotero.app/Contents/MacOS/zotero
ZOTERO_PLUGIN_PROFILE_PATH=/absolute/path/to/agentpaper_zotero/.scaffold/profile
ZOTERO_PLUGIN_DATA_DIR=/absolute/path/to/your/Zotero

# Optional dev-only pref preload for the dedicated dev profile.
# Preferred variable name:
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Temporary compatibility fallback for local dev only. The shipping plugin does not read this.
# API_KEY=sk-your-existing-key
DEEPSEEK_MODEL=deepseek-v4-flash
# Available models: deepseek-v4-flash, deepseek-v4-pro

# Optional: enable Zotero Browser Toolbox and text debug output during `npm start`.
# Set to 1 only when you need host-level debugging.
# ZOTERO_DEBUGGER=1
